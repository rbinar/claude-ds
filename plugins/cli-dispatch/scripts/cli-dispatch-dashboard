#!/usr/bin/env bash
# cli-dispatch-dashboard — launch the local, read-only web dashboard.
# Resolves dashboard-server.mjs (installed share dir → legacy claude-ds → next to this script),
# runs it with node (foreground; Ctrl-C stops), which opens the browser unless --no-open.
# Flags: --port <N> (default 7878; auto-increments if busy), --no-open. Binds 127.0.0.1 only.
set -euo pipefail

command -v node >/dev/null 2>&1 || { echo "cli-dispatch-dashboard: 'node' not found in PATH (required)." >&2; exit 1; }

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SERVER="${CLI_DISPATCH_DASHBOARD_SERVER:-}"
if [ -z "$SERVER" ]; then
  for cand in "$HOME/.local/share/cli-dispatch/dashboard-server.mjs" "$HOME/.local/share/claude-ds/dashboard-server.mjs" "$SCRIPT_DIR/dashboard-server.mjs"; do
    if [ -f "$cand" ]; then SERVER="$cand"; break; fi
  done
fi
[ -n "$SERVER" ] && [ -f "$SERVER" ] || { echo "cli-dispatch-dashboard: dashboard-server.mjs not found (run /cli-dispatch:setup)." >&2; exit 1; }

exec node "$SERVER" "$@"
